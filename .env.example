# Copy this file to .env and fill in your values
# cp .env.example .env

# Provider selection: 'langflow', 'openai' or 'azure'
LLM_PROVIDER=langflow

# LangFlow RAG endpoint configuration
LANGFLOW_BASE_URL=http://localhost:7860
LANGFLOW_FLOW_ID=your-flow-id-here
LANGFLOW_ENDPOINT=/api/v1/run/
LANGFLOW_API_KEY=

# OpenAI configuration (only used if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI configuration (only used if LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Services addresses
SYMEXEC_URL=http://127.0.0.1:8001
AI_SERVICE_URL=http://127.0.0.1:8002

# Output directory
OUTPUT_DIR=output

# Ghidra MCP configuration
GHIDRA_SERVER_URL=http://127.0.0.1:8080/
GHIDRA_MCP_TRANSPORT=stdio
GHIDRA_MCP_HOST=127.0.0.1
GHIDRA_MCP_PORT=8081
